<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.AlkaWallet" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_blue</item>
    </style>

    <!-- Splash Screen theme -->
    <style name="Theme.AlkaWallet.SplashScreen" parent="Theme.SplashScreen">
